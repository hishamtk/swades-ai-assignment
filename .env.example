# LiveKit Cloud — https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Agent name (must match backend agent.py)
AGENT_NAME=swades-agent

# Groq — free tier at https://console.groq.com
GROQ_API_KEY=
# Agent conversation — 8b uses ~10x fewer tokens than 70b on Groq free tier (100k/day)
GROQ_MODEL=llama-3.1-8b-instant
GROQ_SUMMARY_MODEL=llama-3.1-8b-instant

# Deepgram — https://console.deepgram.com (English voice)
DEEPGRAM_API_KEY=

# Sarvam AI — https://www.sarvam.ai (Malayalam / Indic voice; free credits on signup)
SARVAM_API_KEY=

# Agent language: en (English, Deepgram) or ml / malayalam (Malayalam, Sarvam)
AGENT_LANGUAGE=ml

# Optional voice tuning (Malayalam / Sarvam)
# SARVAM_STT_MODEL=saarika:v2.5
# SARVAM_STT_MODEL=saaras:v3
# SARVAM_STT_MODE=transcribe
# SARVAM_TTS_MODEL=bulbul:v2
# SARVAM_TTS_SPEAKER=anushka

# Optional voice tuning (English / Deepgram)
# DEEPGRAM_STT_MODEL=nova-3
# DEEPGRAM_STT_LANGUAGE=en
# DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# Twilio / SIP (for PSTN inbound + warm transfer)
# Configure SIP trunks in LiveKit: https://docs.livekit.io/sip/
# Outbound trunk ID for warm transfer (NOT the inbound trunk — see LiveKit SIP dashboard)
LIVEKIT_SIP_OUTBOUND_TRUNK=ST_xxxxxxxx
# Supervisor phone for warm transfer — must be verified in Twilio on trial accounts
LIVEKIT_SUPERVISOR_PHONE_NUMBER=+1xxxxxxxxxx
LIVEKIT_SIP_NUMBER=+1xxxxxxxxxx
INBOUND_PHONE_NUMBER=+1xxxxxxxxxx

# Copy these to frontend/.env.local for Next.js API routes
# NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
# NEXT_PUBLIC_INBOUND_PHONE_NUMBER=+1xxxxxxxxxx
